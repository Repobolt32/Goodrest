{
  "name": "goodrest",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cap:sync": "cap sync",
    "cap:add": "cap add android",
    "cap:open": "cap open android",
    "lint": "eslint",
    "test": "vitest run",
    "electron:dev": "wait-on http-get://localhost:3000 && electron .",
    "electron:start": "electron .",
    "electron:build": "next build && node scripts/copy-standalone.js && electron-builder --win",
    "electron:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.101.1",
    "@types/dotenv": "^6.1.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.goodrest.dashboard",
    "productName": "Goodrest Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "electron/bell.html",
      "electron/package.json",
      "electron/assets/**/*",
      "electron/.next/standalone/**/*"
    ],
    "asarUnpack": [
      "electron/.next/standalone/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
