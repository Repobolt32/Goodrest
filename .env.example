# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
ADMIN_PASSWORD=admin-password-here
JWT_SECRET=your-super-secret-jwt-key

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# E2E Testing
E2E_VERIFICATION_SECRET=your_e2e_test_secret
E2E_MODE=false

# Supabase DB (for migrations)
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_URL=postgresql://postgres.your-project:your-db-password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Google Maps
GOOGLE_MAPS_API_KEY=your-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key

# Restaurant config
NEXT_PUBLIC_RESTO_LAT=24.797471691999753
NEXT_PUBLIC_RESTO_LNG=85.0100327655486
NEXT_PUBLIC_RESTO_PHONE=+91 98765 43210
