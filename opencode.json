{ "$schema": 
  "https://opencode.ai/config.json", 
  "default_agent": "build", 
  "instructions": ["AGENTS.md"], 
  "mcp": {
    "ref-context": { "type": 
      "remote", "url": 
      "https://api.ref.tools/mcp", 
      "headers": {
        "x-ref-api-key": 
        "{file:.secrets/ref-api-key}"
      },
      "enabled": true
    },
    "chrome-devtools": { "type": 
      "local", "enabled": true, 
      "command": ["npx", "-y", 
      "chrome-devtools-mcp@latest"]
    }
  }
}


